---
// src/pages/about.astro
import Layout from "../layouts/Layout.astro";
---

<Layout title="Acerca de mí">
  <section class="w-full min-h-screen flex items-center justify-center px-6 py-16 bg-gradient-to-br from-white to-gray-50">
   <div class="max-w-6xl w-full bg-white rounded-3xl shadow-xl overflow-hidden grid grid-cols-1 md:grid-cols-2 mt-12">
    
    <div class="p-8 md:p-12 flex flex-col justify-between bg-white">
      <div>
        <span class="text-xs font-bold uppercase tracking-widest text-amber-600 bg-amber-50 px-3 py-1 rounded-full">Diseño de Editorial & Campaña</span>
        <h2 class="text-3xl font-black text-gray-900 tracking-tight mt-3 mb-2">Mond Beauty Barber</h2>
        <p class="text-gray-500 text-sm mb-6">Diseño de flyer promocional para campaña de depilación láser en la inauguración de Pamplona.</p>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6">
          
          <div class="p-4 rounded-xl bg-gray-50 border border-gray-100">
            <span class="text-xl">📸</span>
            <h4 class="text-sm font-bold text-gray-800 mt-2">Imagen & Iconografía</h4>
            <p class="text-xs text-gray-600 mt-1">Fotografías temáticas de alta calidad combinadas con iconos homogéneos para comunicar beneficios inmediatos.</p>
          </div>

          <div class="p-4 rounded-xl bg-gray-50 border border-gray-100">
            <span class="text-xl">🎯</span>
            <h4 class="text-sm font-bold text-gray-800 mt-2">Llamada a la Acción</h4>
            <p class="text-xs text-gray-600 mt-1">Estructura limpia enfocada en la reserva directa y visibilidad clara de precios y bonos de descuento.</p>
          </div>

          <div class="p-4 rounded-xl bg-gray-50 border border-gray-100">
            <span class="text-xl">✨</span>
            <h4 class="text-sm font-bold text-gray-800 mt-2">Logotipo & Marca</h4>
            <p class="text-xs text-gray-600 mt-1">Ubicación estratégica del logo respetando perfectamente sus zonas de seguridad y legibilidad corporativa.</p>
          </div>

          <div class="p-4 rounded-xl bg-gray-50 border border-gray-100">
            <span class="text-xl">📐</span>
            <h4 class="text-sm font-bold text-gray-800 mt-2">Ajustes Técnicos</h4>
            <p class="text-xs text-gray-600 mt-1">Preparación y optimización de archivos finales tanto para impresión como entornos digitales (CMYK / sRGB).</p>
          </div>

        </div>
      </div>

      <div class="border-t border-gray-100 pt-6 mt-8 flex items-center justify-between">
        <div>
          <h5 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Herramientas</h5>
          <div class="flex gap-2 mt-2">
            <span class="text-xs bg-orange-50 text-orange-700 px-3 py-1 rounded-md font-bold border border-orange-100">Illustrator</span>
            <span class="text-xs bg-blue-50 text-blue-700 px-3 py-1 rounded-md font-bold border border-blue-100">Photoshop</span>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-gradient-to-br from-gray-50 to-gray-100 p-8 flex items-center justify-center border-l border-gray-100 relative overflow-hidden min-h-[450px]">
      
      <div class="absolute w-72 h-72 bg-amber-500/5 rounded-full blur-3xl -bottom-10 -right-10"></div>
      
      <div class="relative w-64 h-[380px] flex items-center justify-center">
        
        <div class="absolute w-52 h-[340px] bg-white rounded-2xl shadow-md border border-gray-200/80 overflow-hidden transform translate-x-12 translate-y-4 rotate-6 transition-all duration-300 hover:rotate-12 z-10">
          <img src="/Images/App estetica/laser_final_back.jpg" alt="Flyer Mond Reverso" class="w-full h-full object-cover">
        </div>
        
        <div class="absolute w-52 h-[340px] bg-white rounded-2xl shadow-2xl border border-gray-100 overflow-hidden transform -translate-x-4 -rotate-3 transition-all duration-300 hover:-translate-y-2 hover:rotate-0 z-20">
          <img src="/Images/App estetica/laser_final_front.jpg" alt="Flyer Mond Anverso" class="w-full h-full object-cover">
        </div>

      </div>

    </div>

  </div>
</div>
  </section>
</Layout>
